server {
    listen 443 ssl;

    {% for relay in relay_infrastructure %}
    {% if relay.ip == ansible_host %}
    server_name {{ relay.domain }};
    {% endif %}
    {% endfor %}

    ssl_certificate /etc/nginx/ssl/relay.crt;
    ssl_certificate_key /etc/nginx/ssl/relay.key;

    location / {
        proxy_pass http://{{ backend_internal_ip }}:5000;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_buffering off;
    }
}